{
  "rules": {
    "gifts": {
      ".read": true,
      ".indexOn": ["status", "updatedAt"],
      "$giftId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".validate": "newData.hasChildren(['name', 'url', 'status', 'lockMessage', 'whatsapp', 'updatedAt'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120"
        },
        "url": {
          ".validate": "newData.isString() && newData.val().matches(/^https:\\/\\/.+/)"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'open' || newData.val() === 'closed')"
        },
        "lockMessage": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 600"
        },
        "whatsapp": {
          ".validate": "newData.isString() && newData.val().matches(/^[0-9]{8,20}$/)"
        },
        "updatedAt": {
          ".validate": "newData.isString()"
        },
        "$other": {
          ".validate": true
        }
      }
    },
    "admins": {
      ".read": false,
      ".write": false
    }
  }
}
